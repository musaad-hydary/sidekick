{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidekick",
  "version": "0.1.0",
  "identifier": "com.musaadhydary.sidekick",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sidekick",
        "url": "http://localhost:1420/",
        "width": 300,
        "height": 480,
        "minWidth": 260,
        "minHeight": 380,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": true,
        "shadow": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "http://localhost:1420/#overlay",
        "width": 3840,
        "height": 2160,
        "x": 0,
        "y": 0,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
